# ── Supabase ─────────────────────────────────────────────────────────────
# Trouvables dans Project Settings > API sur le dashboard Supabase
NEXT_PUBLIC_SUPABASE_URL=https://suyfsuvrbdpnnijxspge.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ───────────────────────────────────────────────────────────────
# Mode test pendant le développement, mode live en prod (gère le switch
# via la table app_config.mode_test_paiement comme dans Base44)
STRIPE_SECRET_KEY=
STRIPE_TEST_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Clé publique Stripe (pk_test_... ou pk_live_...) — visible dans Dashboard > Developers > API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs des plans — créer les produits dans Dashboard > Products (mode test)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_SCALE=

# ── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://book-n-pay.com

# ── Cron (protège l'endpoint /api/cron/check-no-shows et les autres crons) ─
CRON_SECRET=

# ── Sécurité interne ─────────────────────────────────────────────────────
# Secret partagé entre routes serveur (jamais exposé au navigateur).
# Protège /api/loyalty/update-status, appelée serveur-à-serveur uniquement.
# Génère une valeur aléatoire longue, ex: openssl rand -hex 32
INTERNAL_API_SECRET=
