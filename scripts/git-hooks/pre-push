#!/bin/sh
# Garde-fou : seul Pierre pousse sur ce repo. Claude Code prepare/committe en
# local mais ne doit jamais lancer git push lui-meme (regle de process suite
# a plusieurs push sans validation explicite du diff, voir memoire projet).
#
# Installation (pas versionne automatiquement, .git/hooks/ n'est jamais suivi
# par git) :
#   git config core.hooksPath scripts/git-hooks
# ou copie manuelle :
#   cp scripts/git-hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
#
# LIMITE CONNUE ET TESTEE : `git push --no-verify` contourne ce hook
# entierement (comportement standard de git, aucun moyen de l'empecher cote
# hook). Ce garde-fou protege contre un push par inadvertance/habitude, pas
# contre un contournement delibere. Claude Code ne doit JAMAIS utiliser
# --no-verify pour passer outre ce hook.

if [ "$ALLOW_PUSH" != "1" ]; then
  echo ""
  echo "Push bloque : seul Pierre pousse sur ce repo."
  echo "Pour autoriser ce push : ALLOW_PUSH=1 git push"
  echo ""
  exit 1
fi

exit 0
